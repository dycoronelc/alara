# URL base del backend Nest (sin /api al final). Obligatoria si el frontend se sirve en otro dominio
# que el API; si no, el login puede recibir 200 con HTML y fallar al interpretar la respuesta.
#
# Ejemplos:
# VITE_API_URL=http://localhost:3000
# VITE_API_URL=https://tu-servicio-api.up.railway.app

VITE_API_URL=
